# Backend (Express) — copy to .env for local overrides.
# On Render Web Service, set these as Environment Variables in the dashboard.

# Port the server binds to. Render sets this automatically — do not hard-code.
PORT=8080

# Full URL of the deployed frontend, with NO trailing slash.
# Used for CORS allow-list. Leave unset to allow any origin (dev only).
# Example for Render: https://airfns-website.onrender.com
FRONTEND_URL=

# Required: Gemini API key for the AI enhancement feature.
GEMINI_API_KEY=

# Required: Resend API key for sending contact-form emails.
RESEND_API_KEY=

# Required: From-address used by Resend (must be a verified sender).
RESEND_FROM_EMAIL=AirFns <hello@airfnssoftwares.com>

# Required: Long random string used to sign cookies/sessions.
SESSION_SECRET=
